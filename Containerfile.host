# Containerfile.host — Sealed bootc host with composefs root + app signing
#
# Pattern follows composefs-rs examples/unified-secureboot:
# 1. Base stage: install all packages
# 2. Kernel stage: bind-mount base, compute composefs digest, build signed UKI
# 3. Final stage: COPY /boot from kernel stage
#
# The final image has the same rootfs content as `base` plus /boot from
# the kernel stage. bootc install puts /boot on the ESP (separate from
# the composefs-verified rootfs), so the digest computed against `base`
# matches what bootc install computes from the container.
#
# Build:
#   podman build -f Containerfile.host \
#     --secret id=secureboot_key,src=sb-db.key \
#     --secret id=secureboot_cert,src=sb-db.crt \
#     -t localhost/sealed-host:latest .

ARG CFSCTL_IMAGE=ghcr.io/cgwalters/ci-sandbox/cfsctl:composefs

# --- Stage: fetch cfsctl ---
FROM quay.io/centos/centos:stream10 AS fetch-cfsctl
ARG CFSCTL_IMAGE
RUN dnf -y install tar gzip && dnf clean all
RUN curl -sLO "https://github.com/oras-project/oras/releases/download/v1.3.1/oras_1.3.1_linux_amd64.tar.gz" && \
    tar xzf oras_1.3.1_linux_amd64.tar.gz oras && rm oras_1.3.1_linux_amd64.tar.gz
RUN ./oras pull "${CFSCTL_IMAGE}" && chmod +x cfsctl

# --- Stage: rootfs-builder (install packages on the bootc base) ---
FROM quay.io/centos-bootc/centos-bootc:stream10 AS rootfs-builder

ARG SEALED_APP_IMAGE=docker://ghcr.io/cgwalters/ci-sandbox/sealed-app:latest

# sbsigntools from EPEL; systemd-boot-unsigned for bootctl install
RUN --mount=type=tmpfs,target=/run --mount=type=tmpfs,target=/tmp \
    dnf -y install epel-release && \
    dnf -y install crun systemd-boot-unsigned systemd-ukify sbsigntools && \
    dnf clean all

COPY --from=fetch-cfsctl /cfsctl /usr/bin/cfsctl

# App-signing certificate + services
COPY app-signing-cert.pem /usr/lib/composefs/app-signing-cert.pem
COPY etc/systemd/system/composefs-load-appkeys.service /etc/systemd/system/
COPY usr/lib/composefs/load-app-keys.sh /usr/lib/composefs/
COPY etc/default/sealed-httpd /etc/default/sealed-httpd
COPY etc/systemd/system/sealed-httpd.service /etc/systemd/system/
COPY usr/lib/composefs/run-sealed-app.sh /usr/lib/composefs/
COPY usr/lib/composefs/stop-sealed-app.sh /usr/lib/composefs/

RUN --mount=type=tmpfs,target=/run --mount=type=tmpfs,target=/tmp \
    sed -i "s|^SEALED_APP_IMAGE=.*|SEALED_APP_IMAGE=${SEALED_APP_IMAGE}|" \
    /etc/default/sealed-httpd && \
    chmod +x /usr/lib/composefs/load-app-keys.sh \
             /usr/lib/composefs/run-sealed-app.sh \
             /usr/lib/composefs/stop-sealed-app.sh && \
    systemctl enable composefs-load-appkeys.service && \
    systemctl enable sealed-httpd.service

# composefs backend uses systemd-boot, not grub/bootupd
RUN --mount=type=tmpfs,target=/run --mount=type=tmpfs,target=/tmp \
    rpm -e bootupd 2>/dev/null || true

# --- Stage: base (flatten to single layer for deterministic digests) ---
# This is the workaround for composefs-rs#132: podman's overlayfs
# layer stitching produces nondeterministic directory timestamps.
# Flattening via FROM scratch + COPY eliminates all layer boundaries.
FROM scratch AS base
COPY --from=rootfs-builder / /
LABEL containers.bootc 1
LABEL ostree.bootable 1
ENV container=oci
STOPSIGNAL SIGRTMIN+3
CMD ["/sbin/init"]

# --- Stage: kernel (compute digest + build signed UKI) ---
FROM base AS kernel
RUN --mount=type=tmpfs,target=/run --mount=type=tmpfs,target=/tmp \
    --mount=type=bind,from=base,target=/target \
    --mount=type=secret,id=secureboot_key \
    --mount=type=secret,id=secureboot_cert <<EORUN
set -xeuo pipefail
mkdir -p /out
bootc container ukify --rootfs /target -- \
  --signtool sbsign \
  --secureboot-private-key /run/secrets/secureboot_key \
  --secureboot-certificate /run/secrets/secureboot_cert \
  --output /out/uki.efi
ls -lh /out/
EORUN
# Move the UKI into /boot with the right name
RUN --mount=type=tmpfs,target=/run --mount=type=tmpfs,target=/tmp \
    kver=$(bootc container inspect --json | jq -r '.kernel.version') && \
    mkdir -p /boot/EFI/Linux && \
    mv /out/uki.efi "/boot/EFI/Linux/${kver}.efi"

# --- Final image: base rootfs + /boot from kernel stage ---
FROM base
COPY --from=kernel /boot /boot
