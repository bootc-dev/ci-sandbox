# Build a CentOS Stream 10 kernel with fs-verity built-in signatures,
# IPE, and composefs-IPE overlay verity integration.
#
# This works as a dist-git overlay: we fetch the c10s kernel SRPM, then
# inject our patches and config overrides using the same mechanisms the
# distro uses (PatchN: + ApplyOptionalPatch, kernel-local for kconfig).
#
# Build: podman build -f Containerfile -t localhost/kernel-fsverity:build .
# Extract: podman run --rm localhost/kernel-fsverity:build \
#            tar -C /out/ -cf - . | tar -C out/ -xvf -

# --- Stage 1: Install build deps and fetch kernel SRPM ---
FROM quay.io/centos/centos:stream10 AS buildroot

RUN dnf -y install 'dnf-command(config-manager)' && \
    dnf config-manager --set-enabled crb && \
    dnf -y install rpm-build yum-utils && \
    dnf -y builddep --skip-unavailable kernel && \
    dnf clean all

RUN dnf download --source kernel && \
    rpm -ivh kernel-*.src.rpm && \
    rm -f kernel-*.src.rpm

# --- Stage 2: Inject patches, config, and build ---
FROM buildroot AS build

# Copy our patches and config overlay into SOURCES (flat, like dist-git)
COPY 0001-overlayfs-lsm-Notify-LSMs-when-overlay-verity-valida.patch \
     0002-ipe-Add-overlay_verity_validated-property-for-compos.patch \
     ~/rpmbuild/SOURCES/

# kernel-local is the distro's intended injection point for custom kconfig
COPY kernel-local ~/rpmbuild/SOURCES/kernel-local

# Register patches in the spec: add PatchN declarations and
# ApplyOptionalPatch calls at the sentinel comments that exist
# specifically for this purpose.
RUN cd ~/rpmbuild/SPECS && \
    sed -i '/^# END OF PATCH DEFINITIONS/i \
Patch1001: 0001-overlayfs-lsm-Notify-LSMs-when-overlay-verity-valida.patch\
Patch1002: 0002-ipe-Add-overlay_verity_validated-property-for-compos.patch' \
        kernel.spec && \
    sed -i '/^# END OF PATCH APPLICATIONS/i \
ApplyOptionalPatch 0001-overlayfs-lsm-Notify-LSMs-when-overlay-verity-valida.patch\
ApplyOptionalPatch 0002-ipe-Add-overlay_verity_validated-property-for-compos.patch' \
        kernel.spec && \
    sed -i 's/^# define buildid .local/%define buildid .fsverity/' \
        kernel.spec

# Build only the base kernel flavour (no debug, no RT, no docs, no tools).
# Even trimmed down this takes 20-40 minutes depending on the machine.
RUN cd ~/rpmbuild/SPECS && \
    rpmbuild -bb \
        --without debug \
        --without debuginfo \
        --without doc \
        --without perf \
        --without libperf \
        --without tools \
        --without bpftool \
        --without selftests \
        --without headers \
        --without cross_headers \
        --target x86_64 \
        kernel.spec

# --- Stage 3: Collect output RPMs ---
FROM quay.io/centos/centos:stream10 AS output
COPY --from=build /root/rpmbuild/RPMS/x86_64/kernel-*.rpm /out/
RUN ls -lh /out/
