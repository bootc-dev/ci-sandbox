 /**
diff --git a/security/ipe/eval.c b/security/ipe/eval.c
index 21439c5be..0854bf702 100644
--- a/security/ipe/eval.c
+++ b/security/ipe/eval.c
@@ -82,6 +82,39 @@ static void build_ipe_inode_ctx(struct ipe_eval_ctx *ctx, const struct inode *co
 }
 #endif /* CONFIG_IPE_PROP_FS_VERITY */
 
+#ifdef CONFIG_IPE_PROP_OVL_VERITY
+/**
+ * build_ipe_ovl_ctx() - Build overlay verity fields of an evaluation context.
+ * @ctx: Supplies a pointer to the context to be populated.
+ * @file: Supplies the file struct of the file triggered IPE event.
+ *
+ * If the file is on an overlayfs mount, record the overlay inode's IPE blob
+ * so we can check if overlay verity validation has been performed.
+ */
+static void build_ipe_ovl_ctx(struct ipe_eval_ctx *ctx,
+			      const struct file *const file)
+{
+	struct inode *ovl_ino = d_inode(file->f_path.dentry);
+
+	/*
+	 * Check for a stacked filesystem via DCACHE_OP_REAL. Currently
+	 * only overlayfs sets this flag. For non-overlay inodes, the
+	 * ovl_verity_validated flag in the IPE blob will be zero-initialized
+	 * (false), so the property fails safe (denies execution). The
+	 * ipe_ovl_inode blob is from the overlay inode (what the process
+	 * sees), NOT the d_real_inode() data inode used for fsverity_digest
+	 * and fsverity_signature properties.
+	 */
+	if (file->f_path.dentry->d_flags & DCACHE_OP_REAL)
+		ctx->ipe_ovl_inode = ipe_inode(ovl_ino);
+}
+#else
+static inline void build_ipe_ovl_ctx(struct ipe_eval_ctx *ctx,
+				     const struct file *const file)
+{
+}
+#endif /* CONFIG_IPE_PROP_OVL_VERITY */
+
 /**
  * ipe_build_eval_ctx() - Build an ipe evaluation context.
  * @ctx: Supplies a pointer to the context to be populated.
@@ -105,6 +138,7 @@ void ipe_build_eval_ctx(struct ipe_eval_ctx *ctx,
 		ino = d_real_inode(file->f_path.dentry);
 		build_ipe_bdev_ctx(ctx, ino);
 		build_ipe_inode_ctx(ctx, ino);
+		build_ipe_ovl_ctx(ctx, file);
 	}
 }
 
@@ -265,6 +299,50 @@ static bool evaluate_fsv_sig_true(const struct ipe_eval_ctx *const ctx)
 }
 #endif /* CONFIG_IPE_PROP_FS_VERITY_BUILTIN_SIG */
 
+#ifdef CONFIG_IPE_PROP_OVL_VERITY
+/**
+ * evaluate_ovl_verity_false() - Evaluate @ctx for overlay verity false.
+ * @ctx: Supplies a pointer to the context being evaluated.
+ *
+ * The ovl_verity_validated flag transitions monotonically from false to true
+ * (never cleared), and fails closed (false → deny execution). READ_ONCE
+ * ensures we see a consistent value despite the flag being set without
+ * holding any lock on the read side.
+ *
+ * Return:
+ * * %true	- The file is NOT overlay-verity validated
+ * * %false	- The file IS overlay-verity validated
+ */
+static bool evaluate_ovl_verity_false(const struct ipe_eval_ctx *const ctx)
+{
+	return !ctx->ipe_ovl_inode ||
+	       !READ_ONCE(ctx->ipe_ovl_inode->ovl_verity_validated);
+}
+
+/**
+ * evaluate_ovl_verity_true() - Evaluate @ctx for overlay verity true.
+ * @ctx: Supplies a pointer to the context being evaluated.
+ *
+ * Return:
+ * * %true	- The file IS overlay-verity validated
+ * * %false	- The file is NOT overlay-verity validated
+ */
+static bool evaluate_ovl_verity_true(const struct ipe_eval_ctx *const ctx)
+{
+	return !evaluate_ovl_verity_false(ctx);
+}
+#else
+static bool evaluate_ovl_verity_false(const struct ipe_eval_ctx *const ctx)
+{
+	return false;
+}
+
+static bool evaluate_ovl_verity_true(const struct ipe_eval_ctx *const ctx)
+{
+	return false;
+}
+#endif /* CONFIG_IPE_PROP_OVL_VERITY */
+
 /**
  * evaluate_property() - Analyze @ctx against a rule property.
  * @ctx: Supplies a pointer to the context to be evaluated.
@@ -297,6 +375,10 @@ static bool evaluate_property(const struct ipe_eval_ctx *const ctx,
 		return evaluate_fsv_sig_false(ctx);
 	case IPE_PROP_FSV_SIG_TRUE:
 		return evaluate_fsv_sig_true(ctx);
+	case IPE_PROP_OVL_VERITY_FALSE:
+		return evaluate_ovl_verity_false(ctx);
+	case IPE_PROP_OVL_VERITY_TRUE:
+		return evaluate_ovl_verity_true(ctx);
 	default:
 		return false;
 	}
