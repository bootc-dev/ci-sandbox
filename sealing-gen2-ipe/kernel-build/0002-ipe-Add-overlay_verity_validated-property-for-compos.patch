diff --git a/security/ipe/hooks.c b/security/ipe/hooks.c
index 0ae54a880..139d03d38 100644
--- a/security/ipe/hooks.c
+++ b/security/ipe/hooks.c
@@ -312,7 +312,8 @@ int ipe_bdev_setintegrity(struct block_device *bdev, enum lsm_integrity_type typ
 }
 #endif /* CONFIG_IPE_PROP_DM_VERITY */
 
-#ifdef CONFIG_IPE_PROP_FS_VERITY_BUILTIN_SIG
+#if defined(CONFIG_IPE_PROP_FS_VERITY_BUILTIN_SIG) || \
+    defined(CONFIG_IPE_PROP_OVL_VERITY)
 /**
  * ipe_inode_setintegrity() - save integrity data from a inode to IPE's LSM blob.
  * @inode: The inode to source the security blob from.
@@ -320,8 +321,8 @@ int ipe_bdev_setintegrity(struct block_device *bdev, enum lsm_integrity_type typ
  * @value: The value to be stored.
  * @size: The size of @value.
  *
- * This hook is currently used to save the existence of a validated fs-verity
- * builtin signature into LSM blob.
+ * This hook is used to save the existence of a validated fs-verity builtin
+ * signature and/or overlay verity validation status into the LSM blob.
  *
  * Return: %0 on success. If an error occurs, the function will return the
  * -errno.
@@ -332,11 +333,25 @@ int ipe_inode_setintegrity(const struct inode *inode,
 {
 	struct ipe_inode *inode_sec = ipe_inode(inode);
 
+#ifdef CONFIG_IPE_PROP_FS_VERITY_BUILTIN_SIG
 	if (type == LSM_INT_FSVERITY_BUILTINSIG_VALID) {
 		inode_sec->fs_verity_signed = size > 0 && value;
 		return 0;
 	}
+#endif /* CONFIG_IPE_PROP_FS_VERITY_BUILTIN_SIG */
+
+#ifdef CONFIG_IPE_PROP_OVL_VERITY
+	if (type == LSM_INT_OVL_VERITY_VALIDATED) {
+		/*
+		 * Set or clear the validated flag. Passing value=NULL or
+		 * size=0 clears it, supporting future overlay invalidation.
+		 */
+		WRITE_ONCE(inode_sec->ovl_verity_validated,
+			   size > 0 && value);
+		return 0;
+	}
+#endif /* CONFIG_IPE_PROP_OVL_VERITY */
 
 	return -EINVAL;
 }
-#endif /* CONFIG_IPE_PROP_FS_VERITY_BUILTIN_SIG */
+#endif /* CONFIG_IPE_PROP_FS_VERITY_BUILTIN_SIG || CONFIG_IPE_PROP_OVL_VERITY */
