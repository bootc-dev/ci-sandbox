diff --git a/security/ipe/Kconfig b/security/ipe/Kconfig
index a110a6cd8..a61376f89 100644
--- a/security/ipe/Kconfig
+++ b/security/ipe/Kconfig
@@ -13,6 +13,7 @@ menuconfig SECURITY_IPE
 	select IPE_PROP_DM_VERITY_SIGNATURE if DM_VERITY && DM_VERITY_VERIFY_ROOTHASH_SIG
 	select IPE_PROP_FS_VERITY if FS_VERITY
 	select IPE_PROP_FS_VERITY_BUILTIN_SIG if FS_VERITY && FS_VERITY_BUILTIN_SIGNATURES
+	select IPE_PROP_OVL_VERITY if OVERLAY_FS && FS_VERITY
 	help
 	  This option enables the Integrity Policy Enforcement LSM
 	  allowing users to define a policy to enforce a trust-based access
@@ -95,6 +96,24 @@ config IPE_PROP_FS_VERITY_BUILTIN_SIG
 
 	  if unsure, answer Y.
 
+config IPE_PROP_OVL_VERITY
+	bool "Enable support for overlay verity validated files"
+	depends on OVERLAY_FS && FS_VERITY
+	help
+	  This option enables the 'overlay_verity_validated' property within
+	  IPE policies. The property evaluates to TRUE when a file is
+	  accessed through an overlayfs mount with verity=require and the
+	  overlay has verified that the file's content matches the fs-verity
+	  digest recorded in the metadata layer.
+
+	  This is the foundation for composefs-style integrity: a signed
+	  EROFS metadata image records per-file fs-verity digests, overlayfs
+	  enforces them, and IPE can gate execution on that verification.
+	  The lower filesystem layers are assumed to be immutable or
+	  read-only (which is the composefs model).
+
+	  If unsure, say Y.
+
 endmenu
 
